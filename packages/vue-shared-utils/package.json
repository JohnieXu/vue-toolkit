{
  "name": "vue-shared-utils",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Vue 3 共享工具方法，供 vue-toolkit 各子包复用",
  "main": "dist/vue-shared-utils.umd.cjs",
  "module": "dist/vue-shared-utils.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/vue-shared-utils.mjs",
      "require": "./dist/vue-shared-utils.umd.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vite": "^6.3.5",
    "vue": "^3.5.13"
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.json",
    "dev": "vite build --watch"
  },
  "keywords": [
    "vue",
    "vue3",
    "utils",
    "shared"
  ],
  "license": "MIT"
}
